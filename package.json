{
  "name": "bc-resilience-service",
  "version": "1.0.0",
  "description": "GitHub Copilot Extension — on-demand OCP resilience posture analysis for BC Gov teams",
  "type": "module",
  "scripts": {
    "build":     "tsc",
    "dev":       "tsx watch src/index.ts",
    "start":     "node dist/index.js",
    "lint":      "eslint src --ext .ts",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@copilot-extensions/preview-sdk": "^1.0.0",
    "@fastify/sensible":               "^5.0.0",
    "@octokit/rest":                   "^21.0.0",
    "fastify":                         "^5.0.0",
    "pino":                            "^9.0.0"
  },
  "devDependencies": {
    "@types/node":                "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser":  "^7.0.0",
    "eslint":                     "^9.0.0",
    "tsx":                        "^4.0.0",
    "typescript":                 "^5.0.0",
    "vitest":                     "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}
