# containerization/Containerfile — bc-resilience-service
# Ryan Loisell — Developer / Architect | GitHub Copilot | April 2026
#
# Multi-stage build: TypeScript compile → lean runtime with pandoc + chromium.
# Compatible with OpenShift random UID (runAsNonRoot=true, gid=0, fsGroup=0).

# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM node:22-slim AS builder

WORKDIR /build
COPY package*.json tsconfig.json ./
RUN npm ci --ignore-scripts
COPY src/ src/
RUN npm run build


# ── Stage 2: Runtime ──────────────────────────────────────────────────────────
FROM node:22-slim AS runtime

# Install render deps
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      pandoc chromium bash curl jq ca-certificates && \
    rm -rf /var/lib/apt/lists/*

ENV NODE_ENV=production \
    PORT=8080 \
    CHROMIUM_PATH=/usr/bin/chromium

WORKDIR /app

# Install production deps
COPY package*.json ./
RUN npm ci --omit=dev --ignore-scripts

# Copy compiled source + toolkit submodule
COPY --from=builder /build/dist ./dist
COPY submodules/ocp-resilience-toolkit ./submodules/ocp-resilience-toolkit

# Make collection / render scripts executable
RUN chmod +x \
      submodules/ocp-resilience-toolkit/collect/collect.sh \
      submodules/ocp-resilience-toolkit/render/render.sh

# Scratch directory with group-write for OpenShift random UID
RUN mkdir -p /tmp/bc-resilience-work && \
    chown -R 1001:0 /tmp/bc-resilience-work && \
    chmod -R g=u /tmp/bc-resilience-work

RUN chown -R 1001:0 /app && chmod -R g=u /app

USER 1001
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8080/health/live || exit 1

CMD ["node", "dist/index.js"]
